    view.RevokeOrders = function (wtrq, wtbh, market, mmlb) {
        alertMsg("", "确认撤销？", "question", function (code) {
            if (code == "1") {
                utools.loadAjax("/Trade/cancelStockWEB", { wtrq: wtrq, wtbh: wtbh, market: market, mmlb: mmlb }, function (result) {
