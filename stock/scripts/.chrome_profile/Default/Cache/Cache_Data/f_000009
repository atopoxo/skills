    function editPage(tag, bl) {
        if (bl) {
            if ($pager.children().length == 0) {
                $pager.html('<div class="confooter"><div class="pager fr"></div></div>');
            }
        }

        var html = '';
        if (_count == 1) {
            if (bl)
                html = '<span>上一页</span>  <span id="nowPage">第 页</span>  <a target="_self" data-page="next" href="javascript:PosPartial.GetData(\'' + tag + '\',\'next\');">下一页</a>';
            else
                $(".confooter").remove();
        } else {
            if (bl)
                html = '<a target="_self" href="javascript:PosPartial.GetData(\'' + tag + '\',\'pre\');">上一页</a>  <span id="nowPage">第 页</span>  <a target="_self" data-page="next" href="javascript:PosPartial.GetData(\'' + tag + '\',\'next\');">下一页</a>';
            else
                html = '<a target="_self" href="javascript:PosPartial.GetData(\'' + tag + '\',\'pre\');">上一页</a>  <span id="nowPage">第 页</span>  <span>下一页</span>';
        }
        $(".pager").html(html);
    }

